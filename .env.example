# =============================================================================
# Cronpilot Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/cronpilot"

# -----------------------------------------------------------------------------
# Redis (BullMQ queues + rate limiting)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"

# JWT expiry duration (e.g. "7d", "24h")
JWT_EXPIRES_IN="7d"

# Port the API server listens on
API_PORT=3001

# CORS: comma-separated list of allowed origins
API_CORS_ORIGINS="http://localhost:3000"

# Encryption key for integration configs (AES-256) — 64 hex chars
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change-me-64-hex-chars-openssl-rand-hex-32-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Encryption IV salt (16 hex chars) — generate with: openssl rand -hex 8
ENCRYPTION_IV_SALT="change-me-16-hex"

# -----------------------------------------------------------------------------
# Web (apps/web — Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Next.js Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"

# -----------------------------------------------------------------------------
# Worker (apps/worker)
# -----------------------------------------------------------------------------
# Worker concurrency per queue
WORKER_CONCURRENCY=5

# How often the check-window job fires (cron, default every minute)
CHECK_WINDOW_SCHEDULE="* * * * *"

# How often the cleanup job fires (cron, default daily at 2am)
CLEANUP_SCHEDULE="0 2 * * *"

# How many days of checkins to keep for free plan (override; default from plans.ts)
# CLEANUP_FREE_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Cronpilot <no-reply@cronpilot.io>"

# -----------------------------------------------------------------------------
# Stripe (billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO="price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_TEAM="price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_ENTERPRISE="price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# Slack OAuth (optional — for Slack integration setup)
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
NODE_ENV="development"

# Sentry DSN for error tracking (optional)
SENTRY_DSN=""
